# ======================
# App
# ======================
NODE_ENV=production
APP_NAME=whiteboard-platform
APP_URL=https://your-domain.com

# ======================
# Database (PostgreSQL)
# ======================
POSTGRES_HOST=wb-postgres
POSTGRES_PORT=5432
POSTGRES_USER=whiteboard
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=whiteboard

# ======================
# Redis
# ======================
REDIS_HOST=wb-redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ======================
# JWT Authentication
# ======================
JWT_SECRET=change_me_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# ======================
# AI (OpenRouter)
# Get your key at: https://openrouter.ai
# ======================
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_DEFAULT_MODEL=anthropic/claude-sonnet-4.6
AI_VISION_MODEL=anthropic/claude-sonnet-4.6
AI_TEMPERATURE=0.7

# ======================
# Hocuspocus (Collab)
# ======================
HOCUSPOCUS_PORT=1234

# ======================
# MinIO (File Storage) - Optional
# ======================
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_BUCKET=whiteboard-assets
MINIO_USE_SSL=false
